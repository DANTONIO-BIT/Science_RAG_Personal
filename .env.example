# ── Gateway (Express) ────────────────────────────────────────────
SAFE_WORKSPACE_ROOT=./safe_workspace
PORT=3001

# ── Cloud escalation ─────────────────────────────────────────────
# PRIMARY: OpenRouter (free tier available — no per-token API billing on :free models)
OPENROUTER_API_KEY=your_key_here
# Optional model override (default: nvidia/nemotron-3-super-120b-a12b:free)
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# OPTIONAL: Anthropic — billed as standard API usage. Only used when
# LLM_CLOUD_PROVIDER=anthropic (router) or by legacy bridge_cloud.py.
# LLM_CLOUD_PROVIDER=openrouter            # openrouter (default) | anthropic
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Notion (optional, used by OpenCode remote MCP) ───────────────
# NOTION_TOKEN=YOUR_NOTION_TOKEN_HERE
# NOTION_DATABASE_ID=YOUR_DATABASE_ID_HERE
